# ─── Supabase (Database + Auth) ───────────────────────────────────────────────
# From Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — server-only, NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string for Prisma migrations.
# From Supabase project → Settings → Database → Connection string → URI.
# Use Session pooler (port 5432). Do NOT use Transaction pooler (6543) — Prisma db push will hang.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# From https://dashboard.razorpay.com/app/keys (use Test keys until you go live)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Same key id, exposed to the browser to open Razorpay Checkout.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Plan IDs you create in the Razorpay dashboard (Subscriptions → Plans).
# ₹99 / month and ₹799 / year.
RAZORPAY_PLAN_ID_MONTHLY=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_ID_YEARLY=plan_xxxxxxxxxxxx

# Webhook secret you set when creating the webhook in Razorpay dashboard.
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── App ──────────────────────────────────────────────────────────────────────
# Used for OAuth redirect + Razorpay callback. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
